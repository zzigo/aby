# Runtime
NODE_ENV=development
PORT=4380
HOST=127.0.0.1
ORIGIN=http://localhost:5173
ABY_LOG_LEVEL=info
ABY_DEMO_MODE=true

# PostgreSQL: Aby owns only the `aby` schema.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
ABY_DATABASE_SCHEMA=aby

# Private Wasabi/S3 storage. ref/ and mov/ are legacy source pools; aby/ is canonical.
WASABI_ENDPOINT=https://s3.REGION.wasabisys.com
WASABI_REGION=REGION
WASABI_BUCKET=BUCKET_NAME
# Optional bucket-relative root. Production maps the logical rclone root
# wasabi:zzttuntref/ to bucket untref-licmusica + prefix zzttuntref/.
WASABI_ROOT_PREFIX=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
ABY_STORAGE_PREFIX=aby/
ABY_AUDIO_PREFIX=aby/aud/
ABY_VIDEO_PREFIX=aby/mov/
ABY_SOURCE_AUDIO_PREFIX=ref/
ABY_SOURCE_VIDEO_PREFIX=mov/
ABY_INGEST_MAX_SOURCE_BYTES=1073741824
ABY_PRESIGNED_URL_TTL_SECONDS=300

# Public metadata services. MusicBrainz requires an identifiable User-Agent.
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
COVER_ART_ARCHIVE_BASE_URL=https://coverartarchive.org
ABY_EXTERNAL_METADATA_CONTACT=https://aby.zztt.org

# Logto: provision a dedicated Aby application; preserve the same subject IDs.
LOGTO_ISSUER_URL=https://IDENTITY_HOST/oidc
LOGTO_CLIENT_ID=
LOGTO_CLIENT_SECRET=
AUTH_SECRET=

# Reconstructible vector index; collection names remain Aby-owned.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
ABY_QDRANT_CLAP_COLLECTION=aby_segments_clap_v1
ABY_QDRANT_MERT_COLLECTION=aby_segments_mert_v1

# External bounded-context APIs. Never point these at private tables.
SESHAT_API_URL=https://seshat.zztt.org/api
SESHAT_INTEGRATION_TOKEN=
MUSIKI_API_URL=https://musiki.org.ar/api
MUSIKI_INTEGRATION_TOKEN=
GLIP_API_URL=
GLIP_INTEGRATION_TOKEN=

# Media tools
FFPROBE_PATH=ffprobe
FFPROBE_TIMEOUT_MS=30000
FPCALC_PATH=bin/fpcalc
ACOUSTID_CLIENT_API_KEY=8Xt5HI6Y
